---
import Layout from "@/layouts/Layout.astro";
---

<Layout title="Stránka nenalezena">
  <header class="flex justify-between mb-52 relative">
    <a href="/" class="flex flex-col sm:gap-4 gap-1">
      <span class="font-head sm:text-5xl text-[7vw]">Malý festival</span>
      <span class="font-head sm:text-3xl text-[4vw]">na velké zahradě</span>
    </a>
    <h1 class="flex flex-col sm:gap-4 gap-1 text-right">
      <span class="font-head sm:text-5xl text-[7vw]">404</span>
      <span class="font-head sm:text-3xl text-[4vw]">Stránka nenalezena</span>
    </h1>
  </header>
  <div class="max-w-xl mx-auto px-4 flex flex-col gap-6">
    <p class="font-head text-2xl sm:text-3xl">Tuhle stránku jsme nenašli.</p>
    <a
      href="/"
      class="text-lg underline underline-offset-4 hover:no-underline transition-all"
    >
      Zpátky na hlavní stránku
    </a>
  </div>
</Layout>
