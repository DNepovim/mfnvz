---
import { getCollection, type CollectionEntry } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Gallery from "@/components/Gallery.svelte";
import { getCloudinaryImages } from "@/utils/cloudinary";

export async function getStaticPaths() {
  const posts = await getCollection("seasons");
  const sorted = [...posts].sort((a, b) => a.id.localeCompare(b.id));
  return sorted.map((post, index) => ({
    params: { id: post.id },
    props: { post, seasonNumber: index + 1 },
  }));
}

type Props = {
  post: CollectionEntry<"seasons">;
  seasonNumber: number;
};

const { post, seasonNumber } = Astro.props;
const imagePublicIds = await getCloudinaryImages({ folder: post.id });
---

<Layout
  title={`Obrázky | ${String(seasonNumber)}. ročník ${post.id}`}
  description={post.data.claim}
>
  <header class="flex justify-between mb-52 relative">
    <a href="/" class="flex flex-col sm:gap-4 gap-1">
      <span class="font-head sm:text-5xl text-[7vw]">Malý festival</span>
      <span class="font-head sm:text-3xl text-[4vw]">na velké zahradě</span>
    </a>
    <h1 class="flex flex-col sm:gap-4 gap-1 text-right">
      <span class="font-head sm:text-5xl text-[7vw]">
        {seasonNumber}. ročník
      </span>
      <span class="font-head sm:text-3xl text-[4vw]">
        {post.data.date.toLocaleDateString("cs-CZ")}
      </span>
    </h1>
  </header>
  <Gallery client:visible year={post.id} imagePublicIds={imagePublicIds} />
</Layout>
