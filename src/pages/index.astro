---
import Cover from "@/components/Cover.svelte";
import Seasons from "@/components/Seasons.astro";
import { getEntry, render } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import H2 from "@/components/H2.astro";
import H3 from "@/components/H3.astro";
import P from "@/components/P.astro";
import Gallery from "@/components/Gallery.svelte";
import BandsLine from "@/components/BandsLine.astro";
import Img from "@/components/Img.astro";
import Ul from "@/components/Ul.astro";
import A from "@/components/A.astro";
import Hr from "@/components/Hr.astro";
import Claim from "@/components/Claim.astro";
import { getCloudinaryImages } from "@/utils/cloudinary";
import type { MusicEvent, WithContext } from "schema-dts";

const post = await getEntry("seasons", "2026");

if (!post) {
  return;
}

const { Content } = await render(post);
const imagePublicIds = await getCloudinaryImages({ folder: post.id });

const seasonNumber = Number(post.id) - 2022;

const schema = {
  "@context": "https://schema.org",
  "@type": "MusicEvent",
  name: `${String(seasonNumber)}. ročník Malého festivalu na velké zahradě`,
  startDate: post.data.date.toISOString(),
  doorTime: post.data.door.toISOString(),
  eventStatus: "https://schema.org/EventScheduled",
  eventAttendanceMode: "https://schema.org/OfflineEventAttendanceMode",
  url: Astro.url.href,
  location: {
    "@type": "Place",
    name: "Velká zahrada v Řevnicích",
    address: {
      "@type": "PostalAddress",
      streetAddress: "Žižkova 257",
      addressLocality: "Řevnice",
      postalCode: "25230",
      addressCountry: "CZ",
    },
  },
  image: post.data.images,
  ...(post.data.claim && { description: post.data.claim }),
  ...(post.data.bands && {
    performer: (post.data.bands ?? []).map((band) => ({
      "@type": "MusicGroup",
      ...band,
      foundingDate: band.foundingDate?.toISOString(),
      member: (band.member ?? []).map((member) => ({
        "@type": "Person",
        ...member,
      })),
    })),
  }),
  ...(post.data.fbEventLink && {
    sameAs: post.data.fbEventLink,
  }),
  organizer: {
    "@type": "Person",
    name: "Dominik Bláha",
    url: new URL("/", Astro.url).href,
    email: "principal@mfnvz.cz",
  },
} satisfies WithContext<MusicEvent>;
---

<Layout currentSeasonId={post.id} description={post.data.claim}>
  <script
    slot="head"
    type="application/ld+json"
    set:html={JSON.stringify(schema)}
  />
  <Cover
    client:load
    image={post.data.cover}
    title="Malý festival"
    subtitle="na velké zahradě"
    subsubtitle={`${post.data.date.toLocaleDateString("cs-CZ")}, 17:00, Řevnice`}
  />
  {post.data.bands && <BandsLine bands={post.data.bands} />}

  <Claim claim={post.data.claim} />

  <div class="max-w-xl mx-auto px-4">
    <Seasons />
    <Content
      components={{
        h2: H2,
        h3: H3,
        p: P,
        a: A,
        ul: Ul,
        img: Img,
        hr: Hr,
      } as Record<string, unknown>}
    />
  </div>

  <Gallery client:visible year={post.id} imagePublicIds={imagePublicIds} />
</Layout>
