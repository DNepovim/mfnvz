---
import type { CollectionEntry } from 'astro:content'

import H2 from '@/components/H2.astro'

type Props = {
  schedule: NonNullable<CollectionEntry<'seasons'>['data']['schedule']>
}

const { schedule } = Astro.props
---

<div class="mx-auto max-w-xl px-4">
  <H2>Harmonogram</H2>
  <ul class="mb-10 text-lg">
    {
      schedule.map((item, index) => (
        <li class="relative">
          <span class="font-head inline-block w-16">
            {item.startDate.toLocaleTimeString('cs-CZ', {
              hour: '2-digit',
              minute: '2-digit',
              hour12: false,
              timeZone: 'UTC',
            })}
          </span>
          {' – '}
          {item.name.toLocaleLowerCase()}
          {index > 0 && (
            <span class="absolute top-0 left-8 h-2 w-px translate-y-full bg-black" />
          )}
        </li>
      ))
    }
  </ul>
</div>
