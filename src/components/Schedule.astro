---
import type { CollectionEntry } from 'astro:content'

import H2 from '@/components/H2.astro'

type Props = {
  schedule: NonNullable<CollectionEntry<'seasons'>['data']['schedule']>
}

const { schedule } = Astro.props
---

<div class="mx-auto max-w-xl px-4">
  <H2>Harmonogram</H2>
  <ul class="mb-10 text-lg">
    {
      schedule.map((item) => (
        <li>
          {item.startDate.toLocaleTimeString('cs-CZ', {
            hour: '2-digit',
            minute: '2-digit',
            hour12: false,
            timeZone: 'UTC',
          })}
          {' – '}
          {item.name}
        </li>
      ))
    }
  </ul>
</div>
