---
type Props = {
  href: string;
  class?: string;
};

const { href, class: className } = Astro.props;
const isExternal = href.startsWith("http");
---

<a
  href={href}
  {...isExternal ? { target: "_blank", rel: "noopener noreferrer" } : {}}
  class:list={[className, "hover:no-underline underline"]}><slot /></a
>
