---
import { Icon } from "astro-icon/components";
import { slugify } from "@/utils/slug";

type Props = {
  className?: string;
  id?: string;
};

const { className, id } = Astro.props;
const slotContent = await Astro.slots.render('default');
const headingId = id ?? slugify(slotContent.replace(/<[^>]*>/g, ''));
---

<h2
  id={headingId}
  class:list={[
    "font-head text-4xl items-start mb-6 mt-16 sm:relative flex gap-2",
    className,
  ]}
>
  <Icon
    name="ph:tree"
    class="w-8 h-8 mt-2 max-sm:hidden flex-[2rem_0_0] sm:absolute sm:-left-6 sm:-translate-x-full"
  />
  <slot />
</h2>
