---
import { CldImage } from 'astro-cloudinary'

type Props = {
  imagePublicUrls: string[]
  galleryId: string
}

const { imagePublicUrls, galleryId } = Astro.props
---

<dialog
  data-gallery-id={galleryId}
  class="m-0 h-dvh max-h-screen w-screen max-w-none touch-pan-y items-center border-none bg-white p-0 open:flex"
  aria-label="Image lightbox"
>
  <button
    type="button"
    data-action="close"
    class="absolute top-4 right-4 z-10 flex cursor-pointer items-center justify-center rounded border-none bg-transparent p-2 text-black hover:bg-black/6"
    aria-label="Close"
  >
    <svg
      xmlns="http://www.w3.org/2000/svg"
      width="24"
      height="24"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
    >
      <path d="M18 6 6 18"></path><path d="m6 6 12 12"></path>
    </svg>
  </button>

  <button
    type="button"
    data-action="prev"
    class="relative z-10 ml-2 flex w-12 shrink-0 cursor-pointer items-center justify-center border-none bg-transparent p-4 text-black hover:bg-black/6"
    aria-label="Previous image"
  >
    <svg
      xmlns="http://www.w3.org/2000/svg"
      width="24"
      height="24"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
    >
      <path d="m15 18-6-6 6-6"></path>
    </svg>
  </button>

  <div
    data-action="swipe"
    class="relative z-10 flex h-full min-w-0 flex-1 items-center justify-center p-8"
  >
    {
      imagePublicUrls.map((id, index) => (
        <CldImage
          src={id}
          alt=""
          width={1920}
          height={1280}
          crop="fit"
          loading="lazy"
          data-index={index}
          class="hidden max-h-full max-w-full rounded-lg object-contain"
          flags={['progressive']}
        />
      ))
    }
  </div>

  <button
    type="button"
    data-action="next"
    class="relative z-10 mr-2 flex w-12 shrink-0 cursor-pointer items-center justify-center border-none bg-transparent p-4 text-black hover:bg-black/6"
    aria-label="Next image"
  >
    <svg
      xmlns="http://www.w3.org/2000/svg"
      width="24"
      height="24"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
    >
      <path d="m9 18 6-6-6-6"></path>
    </svg>
  </button>
</dialog>

<script>
  document
    .querySelectorAll<HTMLDialogElement>('dialog[data-gallery-id]')
    .forEach((dialog) => {
      const galleryId = dialog.dataset.galleryId ?? ''
      const imgs = [...dialog.querySelectorAll<HTMLImageElement>('[data-index]')]
      const count = imgs.length

      let current = 0
      let pointerStartX: number | null = null

      const preload = (img: HTMLImageElement | undefined) => {
        if (img) img.loading = 'eager'
      }

      const show = (index: number) => {
        imgs[current]?.classList.add('hidden')
        current = ((index % count) + count) % count
        const img = imgs[current]!
        img.classList.remove('hidden')
        img.loading = 'eager'
        preload(imgs[(current + 1) % count])
        preload(imgs[(current - 1 + count) % count])
      }

      const open = (index: number) => {
        show(index)
        document.body.style.overflow = 'hidden'
        dialog.showModal()
      }

      const close = () => dialog.close()
      const goPrev = () => show(current - 1)
      const goNext = () => show(current + 1)

      dialog.querySelector('[data-action="close"]')?.addEventListener('click', close)
      dialog.querySelector('[data-action="prev"]')?.addEventListener('click', goPrev)
      dialog.querySelector('[data-action="next"]')?.addEventListener('click', goNext)

      dialog.addEventListener('click', (e) => {
        if (e.target === dialog) close()
      })
      dialog.addEventListener('cancel', close)
      dialog.addEventListener('close', () => {
        document.body.style.overflow = ''
      })

      dialog.addEventListener('keydown', (e) => {
        if (e.key === 'ArrowLeft') goPrev()
        if (e.key === 'ArrowRight') goNext()
      })

      const swipeArea = dialog.querySelector('[data-action="swipe"]')!
      swipeArea.addEventListener('pointerdown', (e) => {
        pointerStartX = (e as PointerEvent).clientX
      })
      swipeArea.addEventListener('pointerup', (e) => {
        if (pointerStartX === null) return
        const delta = (e as PointerEvent).clientX - pointerStartX
        if (delta < -50) goNext()
        else if (delta > 50) goPrev()
        pointerStartX = null
      })
      swipeArea.addEventListener('pointerleave', () => {
        pointerStartX = null
      })

      document.addEventListener('gallery:open', (e) => {
        const { index, galleryId: id } = (
          e as CustomEvent<{ index: number; galleryId: string }>
        ).detail
        if (id !== galleryId) return
        if (!window.matchMedia('(min-width: 768px)').matches) return
        open(index)
      })
    })
</script>
