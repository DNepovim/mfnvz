---
import { slugify } from '@/utils/slug'

type Props = {
  bands: { name: string }[]
}

const { bands } = Astro.props
---

<p
  class="text-lg mt-8 mb-8 flex items-center gap-4 px-4 font-thin max-sm:flex-wrap max-sm:justify-around sm:text-2xl"
>
  {
    bands.map(({ name }, i) => (
      <>
  <a href={`#${slugify(name)}`} class="whitespace-nowrap max-sm:block max-sm:w-[40%] text-center hover:underline">{name}</a>
        {i < bands.length - 1 && (
          <span class="h-[0.5px] flex-1 bg-gray-700 max-sm:hidden" />
        )}
      </>
    ))
  }
</p>
