---
import Analytics from "@vercel/analytics/astro";
import Footer from "@/components/Footer.astro";
import "@/styles/global.css";
import { UMAMI_SITE_ID } from "astro:env/client";
import favicon from "@/favicon.svg";

const SITE_TITLE = "Malý festival na velké zahradě";

type Props = {
  currentSeasonId?: string;
  title?: string;
  description?: string;
};

const { currentSeasonId, title, description } = Astro.props;

const config = {
  url: "https://cloud.umami.is/script.js",
  websiteId: UMAMI_SITE_ID,
} as const;
---

<!doctype html>
<html lang="cs" class="font-text">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href={favicon.src} />
    <meta name="generator" content={Astro.generator} />
    <title>{title ? `${title} | ${SITE_TITLE}` : SITE_TITLE}</title>
    {description && <meta name="description" content={description} />}
    <link rel="stylesheet" href="https://use.typekit.net/tai1czq.css" />
    <script is:inline defer src={config.url} data-website-id={config.websiteId}
    ></script>
    <slot name="head" />
  </head>
  <body>
    <Analytics />
    <main id="swup" class="max-w-6xl mx-auto pt-2 sm:pt-4 pb-20 px-1 sm:px-8">
      <slot />
      <Footer currentSeasonId={currentSeasonId} />
    </main>
  </body>
</html>
